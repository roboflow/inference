{
  "version": "1.0",
  "inputs": [
    {"type": "WorkflowImage", "name": "image"},
    {"type": "WorkflowParameter", "name": "enable_email", "default_value": true}
  ],
  "steps": [
    {
      "type": "roboflow_core/roboflow_object_detection_model@v3",
      "name": "detection",
      "image": "$inputs.image",
      "model_id": "yolov8n-640",
      "class_filter": ["person"]
    },
    {
      "type": "ContinueIf",
      "name": "continue_if_email_enabled",
      "condition_statement": {
        "type": "StatementGroup",
        "statements": [
          {
            "type": "UnaryStatement",
            "operand": {
              "type": "DynamicOperand",
              "operand_name": "left"
            },
            "operator": {
              "type": "(Boolean) is True"
            }
          }
        ]
      },
      "evaluation_parameters": {
        "left": "$inputs.enable_email"
      },
      "next_steps": ["$steps.continue_if"]
    },
    {
      "type": "ContinueIf",
      "name": "continue_if",
      "condition_statement": {
        "type": "StatementGroup",
        "statements": [
          {
            "type": "BinaryStatement",
            "left_operand": {
              "type": "DynamicOperand",
              "operand_name": "prediction",
              "operations": [{"type": "SequenceLength"}]
            },
            "comparator": {"type": "(Number) >="},
            "right_operand": {
              "type": "StaticOperand",
              "value": 1
            }
          }
        ]
      },
      "evaluation_parameters": {"prediction": "$steps.detection.predictions"},
      "next_steps": ["$steps.email_notification"]
    },
    {
      "type": "roboflow_core/email_notification@v2",
      "name": "email_notification",
      "subject": "Detections found",
      "receiver_email": "noreply@example.com",
      "message": "Found {{ $parameters.num_detections }} detection(s) for this image.",
      "message_parameters": {
        "num_detections": "$steps.detection.predictions"
      },
      "message_parameters_operations": {
        "num_detections": [{"type": "SequenceLength"}]
      },
      "cooldown_seconds": 0
    }
  ],
  "outputs": [
    {
      "type": "JsonField",
      "name": "email_message",
      "selector": "$steps.email_notification.message"
    }
  ]
}
