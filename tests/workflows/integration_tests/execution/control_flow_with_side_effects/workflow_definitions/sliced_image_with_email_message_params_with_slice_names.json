{
  "version": "1.0",
  "inputs": [
    {"type": "WorkflowImage", "name": "image"},
    {"type": "WorkflowBatchInput", "name": "names", "dimensionality": 2}
  ],
  "steps": [
    {
      "type": "roboflow_core/image_slicer@v2",
      "name": "image_slicer",
      "image": "$inputs.image",
      "slice_width": 640,
      "slice_height": 640,
      "overlap_ratio_width": 0.2,
      "overlap_ratio_height": 0.2
    },
    {
      "type": "roboflow_core/roboflow_object_detection_model@v2",
      "name": "detection",
      "image": "$steps.image_slicer.slices",
      "model_id": "yolov8n-640",
      "class_filter": ["person"]
    },
    {
      "type": "ContinueIf",
      "name": "continue_if",
      "condition_statement": {
        "type": "StatementGroup",
        "statements": [
          {
            "type": "BinaryStatement",
            "left_operand": {
              "type": "DynamicOperand",
              "operand_name": "prediction",
              "operations": [{"type": "SequenceLength"}]
            },
            "comparator": {"type": "(Number) >="},
            "right_operand": {
              "type": "StaticOperand",
              "value": 1
            }
          }
        ]
      },
      "evaluation_parameters": {"prediction": "$steps.detection.predictions"},
      "next_steps": ["$steps.email_notification"]
    },
    {
      "type": "roboflow_core/email_notification@v2",
      "name": "email_notification",
      "subject": "Detections found",
      "receiver_email": "noreply@example.com",
      "message": "Image: {{ $parameters.name }}\nFound {{ $parameters.num_detections }} detection(s) for this image.",
      "message_parameters": {
        "num_detections": "$steps.detection.predictions",
        "name": "$inputs.names"
      },
      "message_parameters_operations": {
        "num_detections": [{"type": "SequenceLength"}]
      },
      "cooldown_seconds": 0
    }
  ],
  "outputs": [
    {
      "type": "JsonField",
      "name": "email_message",
      "selector": "$steps.email_notification.message"
    }
  ]
}
