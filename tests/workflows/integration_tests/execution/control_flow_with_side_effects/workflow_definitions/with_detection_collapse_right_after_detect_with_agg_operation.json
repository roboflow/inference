{
  "version": "1.0",
  "inputs": [
    {"type": "WorkflowImage", "name": "image"}
  ],
  "steps": [
    {
      "type": "roboflow_core/roboflow_object_detection_model@v2",
      "name": "detection",
      "image": "$inputs.image",
      "model_id": "yolov8n-640",
      "class_filter": ["person"]
    },
    {
      "type": "roboflow_core/dimension_collapse@v1",
      "name": "collapsed_detections",
      "data": "$steps.detection.predictions"
    },
    {
      "type": "ContinueIf",
      "name": "continue_if",
      "condition_statement": {
        "type": "StatementGroup",
        "statements": [
          {
            "type": "BinaryStatement",
            "left_operand": {
              "type": "DynamicOperand",
              "operand_name": "prediction",
              "operations": [
                {
                  "type": "SequenceApply",
                  "operations": [{"type": "SequenceLength"}]
                },
                {
                  "type": "NumericSequenceAggregate",
                  "function": "sum",
                  "neutral_value": 0
                }
              ]
            },
            "comparator": {"type": "(Number) >="},
            "right_operand": {
              "type": "StaticOperand",
              "value": 3
            }
          }
        ]
      },
      "evaluation_parameters": {"prediction": "$steps.collapsed_detections.output"},
      "next_steps": ["$steps.email_notification"]
    },

    {
      "type": "roboflow_core/email_notification@v2",
      "name": "email_notification",
      "subject": "Detections found",
      "receiver_email": "noreply@example.com",
      "message": "Found {{ $parameters.num_batch_detections }} detection(s) across the batch (at least one image had detections).",
      "message_parameters": {
        "num_batch_detections": "$steps.collapsed_detections.output"
      },
      "message_parameters_operations": {
        "num_batch_detections": [
          {"type": "SequenceApply", "operations": [{"type": "SequenceLength"}]},
          {"type": "NumericSequenceAggregate", "function": "sum", "neutral_value": 0}
        ]
      },
      "cooldown_seconds": 0
    }
  ],
  "outputs": [
    {
      "type": "JsonField",
      "name": "email_message",
      "selector": "$steps.email_notification.message"
    }
  ]
}
