{
  "version": "1.0",
  "inputs": [
    {"type": "WorkflowImage", "name": "image"}
  ],
  "steps": [
    {
      "type": "roboflow_core/image_slicer@v2",
      "name": "image_slicer",
      "image": "$inputs.image",
      "slice_width": 640,
      "slice_height": 640,
      "overlap_ratio_width": 0.2,
      "overlap_ratio_height": 0.2
    },
    {
      "type": "roboflow_core/roboflow_object_detection_model@v2",
      "name": "detection",
      "image": "$steps.image_slicer.slices",
      "model_id": "yolov8n-640",
      "class_filter": ["person"]
    },
    {
      "type": "roboflow_core/roboflow_object_detection_model@v2",
      "name": "detection_image",
      "image": "$inputs.image",
      "model_id": "yolov8s-640",
      "class_filter": ["person"]
    },
    {
      "type": "ContinueIf",
      "name": "continue_if",
      "condition_statement": {
        "type": "StatementGroup",
        "statements": [
          {
            "type": "BinaryStatement",
            "left_operand": {
              "type": "DynamicOperand",
              "operand_name": "prediction",
              "operations": [{"type": "SequenceLength"}]
            },
            "comparator": {"type": "(Number) >="},
            "right_operand": {
              "type": "StaticOperand",
              "value": 1
            }
          }
        ]
      },
      "evaluation_parameters": {"prediction": "$steps.detection.predictions"},
      "next_steps": ["$steps.detections_stitch"]
    },
    {
      "type": "ContinueIf",
      "name": "continue_if_image_detection",
      "condition_statement": {
        "type": "StatementGroup",
        "statements": [
          {
            "type": "BinaryStatement",
            "left_operand": {
              "type": "DynamicOperand",
              "operand_name": "prediction",
              "operations": [{"type": "SequenceLength"}]
            },
            "comparator": {"type": "(Number) >="},
            "right_operand": {
              "type": "StaticOperand",
              "value": 1
            }
          }
        ]
      },
      "evaluation_parameters": {"prediction": "$steps.detection_image.predictions"},
      "next_steps": ["$steps.detections_stitch"]
    },
    {
      "type": "roboflow_core/bounding_box_visualization@v1",
      "name": "detection_image_bbox_visualization",
      "image": "$inputs.image",
      "predictions": "$steps.detection_image.predictions"
    },
    {
      "type": "roboflow_core/detections_stitch@v1",
      "name": "detections_stitch",
      "reference_image": "$steps.detection_image_bbox_visualization.image",
      "predictions": "$steps.detection.predictions"
    }
  ],
  "outputs": [
    {
      "type": "JsonField",
      "name": "stitched_predictions",
      "selector": "$steps.detections_stitch.predictions"
    }
  ]
}
