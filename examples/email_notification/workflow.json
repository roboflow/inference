{
    "version": "1.0",
    "inputs": [
      {"type": "WorkflowImage", "name": "image"}
    ],
    "steps": [
      {
        "type": "RoboflowObjectDetectionModel",
        "name": "detection",
        "image": "$inputs.image",
        "model_id": "yolov8n-640",
        "class_filter": ["person"]
      },
      {
        "type": "roboflow_core/email_notification@v2",
        "name": "email_notification",
        "subject": "Detections found",
        "receiver_email": "noreply@example.com",
        "message": "Found {{ $parameters.num_detections }} detection(s) for this image.",
        "message_parameters": {
          "num_detections": "$steps.detection.predictions"
        },
        "message_parameters_operations": {
          "num_detections": [{"type": "SequenceLength"}]
        }
      }
    ],
    "outputs": [
      {
        "type": "JsonField",
        "name": "email_message",
        "selector": "$steps.email_notification.message"
      }
    ]
}
