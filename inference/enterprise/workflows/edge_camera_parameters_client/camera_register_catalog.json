{
    "schemaVersion": 1,
    "cameraFamilies": {
        "usb": { "label": "USB camera" },
        "ai1": { "label": "AI1" },
        "basler": { "label": "Basler area scan" },
        "basler_line_scan": { "label": "Basler line scan" },
        "lucid": { "label": "Lucid area scan" },
        "lucid_line_scan": { "label": "Lucid line scan" }
    },
    "registers": {
        "focus": {
            "label": "Focus (lens position)",
            "bindings": {
                "ai1": {
                    "settingsRoot": "usb_camera_settings",
                    "parameterDelta": {
                        "v4l2_camera_properties": { "lens_position": "{{value}}" }
                    },
                    "hardwareKeys": ["v4l2_camera_properties.lens_position"],
                    "valueSchema": { "type": "integer", "min": 0, "max": 2294, "step": 1 }
                },
                "usb": {
                    "settingsRoot": "usb_camera_settings",
                    "parameterDelta": {
                        "v4l2_camera_properties": { "lens_position": "{{value}}" }
                    },
                    "hardwareKeys": ["v4l2_camera_properties.lens_position"],
                    "valueSchema": { "type": "integer" }
                }
            }
        },
        "line_rate": {
            "label": "Line rate",
            "bindings": {
                "basler_line_scan": {
                    "settingsRoot": "basler_camera_settings",
                    "parameterDelta": { "AcquisitionLineRate": "{{value}}" },
                    "hardwareKeys": ["AcquisitionLineRate"],
                    "valueSchema": { "type": "number", "unit": "hertz", "unitLabel": "Hz" }
                },
                "lucid_line_scan": {
                    "settingsRoot": "lucid_camera_settings",
                    "parameterDelta": { "AcquisitionLineRate": "{{value}}" },
                    "hardwareKeys": ["AcquisitionLineRate"],
                    "valueSchema": { "type": "number", "unit": "hertz", "unitLabel": "Hz" }
                }
            }
        },
        "exposure_time": {
            "label": "Exposure time",
            "bindings": {
                "ai1": {
                    "settingsRoot": "usb_camera_settings",
                    "parameterDelta": {
                        "v4l2_camera_properties": {
                            "exposure_mode": 0,
                            "exposure_time": "{{value}}"
                        }
                    },
                    "hardwareKeys": [
                        "v4l2_camera_properties.exposure_mode",
                        "v4l2_camera_properties.exposure_time"
                    ],
                    "valueSchema": {
                        "type": "integer",
                        "unit": "microseconds",
                        "unitLabel": "µs",
                        "min": 50,
                        "max": 300,
                        "step": 1
                    }
                },
                "basler_line_scan": {
                    "settingsRoot": "basler_camera_settings",
                    "parameterDelta": { "ExposureTime": "{{value}}" },
                    "hardwareKeys": ["ExposureTime"],
                    "valueSchema": { "type": "number", "unit": "microseconds", "unitLabel": "µs" }
                },
                "lucid_line_scan": {
                    "settingsRoot": "lucid_camera_settings",
                    "parameterDelta": { "ExposureTime": "{{value}}" },
                    "hardwareKeys": ["ExposureTime"],
                    "valueSchema": { "type": "number", "unit": "microseconds", "unitLabel": "µs" }
                }
            }
        },
        "lines_per_frame": {
            "label": "Lines per frame",
            "bindings": {
                "basler_line_scan": {
                    "settingsRoot": "basler_camera_settings",
                    "parameterDelta": { "LinesPerFrame": "{{value}}" },
                    "hardwareKeys": ["LinesPerFrame"],
                    "valueSchema": { "type": "integer", "min": 1, "step": 1 }
