                    "settingsRoot": "usb_camera_settings",
                    "parameterDelta": { "v4l2_camera_properties": { "brightness": "{{value}}" } },
                    "hardwareKeys": ["v4l2_camera_properties.brightness"],
                    "valueSchema": { "type": "integer", "min": 0, "max": 255, "step": 1 }
