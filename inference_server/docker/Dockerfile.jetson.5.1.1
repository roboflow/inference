# syntax=docker/dockerfile:1
#
# Jetson / JetPack 5.1.1 (L4T r35.2.1, Xavier / older Orin). Build: linux/arm64.
#
# JP5's native python is 3.8 (< our >=3.10 floor). The custom base image bakes
# python3.12 + CUDA 11.8 + cuDNN + TensorRT 10 + the jetson aarch64 pip index,
# so we reuse it instead of compiling python ourselves. (Base is built in a
# separate repo and published to Docker Hub; same base the legacy jp5.1.1 and
# inference-experimental jp51 images use.)
#
# Unlike the jp6 file we DON'T use a fresh uv venv or the pyproject [torch-*]/
# [onnx-*] extras: pyproject has no jp5 aarch64 index. Instead we pip the proven
# aarch64 wheels explicitly into the base's system python, then editable-install
# our three packages WITHOUT torch/onnx extras so the baked torch is not clobbered
# (torch==2.4.1 already satisfies inference-models' torch>=2.0,<3.0).

FROM roboflow/l4t-ml:r35.2.1-py3.12-cu118-trt-10-v0.0.3

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    OPENBLAS_CORETYPE=ARMV8 \
    LD_PRELOAD=/usr/lib/aarch64-linux-gnu/libgomp.so.1

RUN apt-get update && apt-get install -y --no-install-recommends \
        git curl ca-certificates openssl \
        libgl1 libglib2.0-0 libvips ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY inference_models        /app/inference_models
COPY inference_model_manager /app/inference_model_manager
COPY inference_server        /app/inference_server

# Reuse the legacy jp5.1.1 aarch64 pin set (jetson wheels from the base's index).
RUN python -m pip install --no-cache-dir \
        "torch==2.4.1" \
        "torchvision==0.19.1" \
        "onnxruntime-gpu>=1.17.0,<1.22.0" \
        "pycuda>=2025.0.0,<2026.0.0" \
        onnx protobuf

# Editable install WITHOUT torch/onnx extras → keeps the aarch64 torch above.
# [cuda] only adds pycuda (already present) + nvidia-ml-py.
RUN python -m pip install --no-cache-dir \
        -e ./inference_models \
        -e "./inference_model_manager[cuda]" \
        -e ./inference_server

WORKDIR /app/inference_server

EXPOSE 8000

# l4t-ml base sets ENTRYPOINT ["bash"] (non-passthrough) → reset it, else CMD
# would run as `bash /bin/bash start_server.sh`.
ENTRYPOINT []
CMD ["/bin/bash", "start_server.sh"]
