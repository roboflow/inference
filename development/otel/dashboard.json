{
  "dashboard": {
    "panels": [
      {
        "datasource": {
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 5
                },
                {
                  "color": "red",
                  "value": 10
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 0
        },
        "targets": [
          {
            "expr": "inference_models_loaded",
            "legendFormat": "{{ service_instance_id }}"
          }
        ],
        "title": "Models Currently Loaded",
        "type": "stat"
      },
      {
        "datasource": {
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 6,
          "y": 0
        },
        "targets": [
          {
            "expr": "sum(inference_model_infer_count_total)",
            "legendFormat": "total"
          }
        ],
        "title": "Total Inferences",
        "type": "stat"
      },
      {
        "datasource": {
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 0.5
                },
                {
                  "color": "red",
                  "value": 2
                }
              ]
            },
            "unit": "s"
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 12,
          "y": 0
        },
        "targets": [
          {
            "expr": "sum(inference_model_infer_duration_seconds_sum) / sum(inference_model_infer_duration_seconds_count)",
            "legendFormat": "avg"
          }
        ],
        "title": "Avg Inference Latency",
        "type": "stat"
      },
      {
        "datasource": {
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 10
                },
                {
                  "color": "red",
                  "value": 50
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 18,
          "y": 0
        },
        "targets": [
          {
            "expr": "sum(inference_model_loads_total)",
            "legendFormat": "total loads"
          }
        ],
        "title": "Total Cold Starts",
        "type": "stat"
      },
      {
        "datasource": {
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "custom": {}
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 4
        },
        "options": {
          "displayMode": "gradient",
          "orientation": "horizontal",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ],
            "fields": "",
            "values": false
          }
        },
        "targets": [
          {
            "expr": "inference_model_infer_count_total",
            "legendFormat": "{{ model_id }}"
          }
        ],
        "title": "Inference Count by Model",
        "type": "bargauge"
      },
      {
        "datasource": {
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "custom": {},
            "unit": "s"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 4
        },
        "options": {
          "displayMode": "gradient",
          "orientation": "horizontal",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ],
            "fields": "",
            "values": false
          }
        },
        "targets": [
          {
            "expr": "inference_model_infer_duration_seconds_sum / inference_model_infer_duration_seconds_count",
            "legendFormat": "avg {{ model_id }}"
          }
        ],
        "title": "Avg Inference Latency by Model",
        "type": "bargauge"
      },
      {
        "datasource": {
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "fillOpacity": 5,
              "lineWidth": 2
            },
            "unit": "s"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 12
        },
        "options": {
          "displayMode": "gradient",
          "orientation": "horizontal",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ],
            "fields": "",
            "values": false
          }
        },
        "targets": [
          {
            "expr": "inference_model_load_duration_seconds_sum / inference_model_load_duration_seconds_count",
            "legendFormat": "avg {{ model_id }}"
          }
        ],
        "title": "Model Load Time",
        "type": "bargauge"
      },
      {
        "datasource": {
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "fillOpacity": 10,
              "lineWidth": 2
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 12
        },
        "options": {
          "displayMode": "gradient",
          "orientation": "horizontal",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ],
            "fields": "",
            "values": false
          }
        },
        "targets": [
          {
            "expr": "inference_model_loads_total",
            "legendFormat": "load {{ model_id }}"
          },
          {
            "expr": "inference_model_unloads_total",
            "legendFormat": "unload {{ model_id }}"
          }
        ],
        "title": "Model Loads & Unloads",
        "type": "bargauge"
      },
      {
        "datasource": {
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "fillOpacity": 20,
              "lineWidth": 2
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 20
        },
        "targets": [
          {
            "expr": "inference_models_loaded",
            "legendFormat": "{{ service_instance_id }}"
          }
        ],
        "title": "Models Loaded Over Time",
        "type": "timeseries"
      },
      {
        "datasource": {
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "fillOpacity": 10,
              "lineWidth": 2
            },
            "unit": "reqps"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 20
        },
        "targets": [
          {
            "expr": "sum(rate(inference_errors_total[5m])) by (error_type)",
            "legendFormat": "{{ error_type }}"
          }
        ],
        "title": "Errors by Type",
        "type": "timeseries"
      },
      {
        "datasource": {
          "uid": "tempo"
        },
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 28
        },
        "targets": [
          {
            "limit": 20,
            "queryType": "nativeSearch",
            "serviceName": "inference-server"
          }
        ],
        "title": "Recent Traces",
        "type": "table"
      }
    ],
    "refresh": "10s",
    "tags": [
      "inference",
      "otel"
    ],
    "time": {
      "from": "now-30m",
      "to": "now"
    },
    "timezone": "browser",
    "title": "Inference Server - OpenTelemetry"
  },
  "overwrite": true
}
